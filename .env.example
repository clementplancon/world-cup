# Copy to .env and fill in real values. NEVER commit the real .env.

# football-data.org API key (10 req/min free tier)
FOOTBALL_DATA_API_KEY=

# Port the Node server listens on (Caddy reverse-proxies to it)
PORT=3000

# Public origin of the front-end, used for the CORS header
PUBLIC_ORIGIN=https://clementplancon.github.io

# --- Phase 2 (Web Push) — generate once with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# --- Phase 3 (OG image) — public URL Puppeteer screenshots ---
SITE_URL=https://clementplancon.github.io/world-cup/
